module aludec (
    input  logic       opb5,       // op[5]
    input  logic [2:0] funct3,
    input  logic       funct7b5,   // funct7[5]
    input  logic [1:0] ALUOp,
    output logic [2:0] ALUControl
);
    logic RtypeSub;
    assign RtypeSub = funct7b5 & opb5; // TRUE for R-type subtract instruction

    always_comb
        case(ALUOp)
            2'b00:   ALUControl = 3'b010; // add (lw, sw, add) 
            2'b01:   ALUControl = 3'b110; // sub. (for beq) 
            default: case(funct3)         // R-type 
                        3'b000: if (RtypeSub) ALUControl = 3'b110; // sub 
                                else          ALUControl = 3'b010; // add 
                        3'b010:               ALUControl = 3'b111; // slt 
                        3'b110:               ALUControl = 3'b001; // or 
                        3'b111:               ALUControl = 3'b000; // and 
                        default:              ALUControl = 3'bxxx; // undefined
                     endcase
        endcase
endmodule